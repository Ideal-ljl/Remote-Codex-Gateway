# Copy this file to config.env, then edit it for the target server.
# Keep this file as shell-compatible KEY=value syntax.

# Public gateway address. Codex clients use:
#   http://<server-ip-or-domain>:${REMOTE_GATEWAY_WEB_PORT}/v1
REMOTE_GATEWAY_WEB_PORT=48761
REMOTE_GATEWAY_PUBLIC_BASE_URL=http://127.0.0.1:48761
# REMOTE_GATEWAY_BIND_ADDR=0.0.0.0:48761

# Runtime data. Do not commit this directory.
REMOTE_GATEWAY_DATA_DIR=

# Optional service binary override. Leave empty to auto-detect:
#   deploy/remote-codex-gateway/bin/<platform>/codexmanager-service
#   deploy/remote-codex-gateway/bin/codexmanager-service
# REMOTE_GATEWAY_SERVICE_BIN=/absolute/path/to/codexmanager-service

# Build proxy for native Cargo builds only. install-rust does not read this;
# it uses the current shell network/proxy environment as-is.
# REMOTE_GATEWAY_BUILD_PROXY_URL=http://127.0.0.1:7890
# REMOTE_GATEWAY_FORCE_BUILD=0

# Optional rustup mirrors for install-rust.
# RUSTUP_DIST_SERVER=https://rsproxy.cn
# RUSTUP_UPDATE_ROOT=https://rsproxy.cn/rustup
# Or:
# RUSTUP_DIST_SERVER=https://mirrors.ustc.edu.cn/rust-static
# RUSTUP_UPDATE_ROOT=https://mirrors.ustc.edu.cn/rust-static/rustup
# RUSTUP_INIT_URL=https://rsproxy.cn/rustup-init.sh

# Optional Cargo crates.io mirror for native builds.
REMOTE_GATEWAY_CARGO_REGISTRY_MIRROR=rsproxy
# REMOTE_GATEWAY_CARGO_REGISTRY_MIRROR=ustc
# REMOTE_GATEWAY_CARGO_REGISTRY_INDEX=sparse+https://example.com/crates.io-index/

# Upstream proxy for the running gateway -> OpenAI/ChatGPT.
# If the proxy runs on the same server, this is usually the 7890 port you mentioned.
# CODEXMANAGER_UPSTREAM_PROXY_URL=http://127.0.0.1:7890

# Optional per-account proxy pool. Leave empty when using CODEXMANAGER_UPSTREAM_PROXY_URL.
# CODEXMANAGER_PROXY_LIST=http://proxy-a:7890,http://proxy-b:7890

# Account slots. Slot names such as primary/backup are the short names used by CLI account commands.
# Lower PRIORITY means earlier use when CODEXMANAGER_ROUTE_STRATEGY=ordered.
# To add accounts:
#   ./start.sh login primary
#   ./start.sh login backup
REMOTE_GATEWAY_ACCOUNTS=primary,backup
REMOTE_GATEWAY_LOGIN_ACCOUNT=primary
REMOTE_GATEWAY_ACCOUNT_PRIMARY_TAGS=primary
REMOTE_GATEWAY_ACCOUNT_PRIMARY_NOTE="Primary Codex Pro account"
REMOTE_GATEWAY_ACCOUNT_PRIMARY_PRIORITY=0
REMOTE_GATEWAY_ACCOUNT_BACKUP_TAGS=backup
REMOTE_GATEWAY_ACCOUNT_BACKUP_NOTE="Backup Codex Pro account"
REMOTE_GATEWAY_ACCOUNT_BACKUP_PRIORITY=10
REMOTE_GATEWAY_APPLY_CONFIG_AFTER_LOGIN=1

# Routing and quota thresholds.
CODEXMANAGER_ROUTE_STRATEGY=ordered
CODEXMANAGER_QUOTA_GUARD_ENABLED=1
CODEXMANAGER_QUOTA_GUARD_5H_MIN_REMAINING_PERCENT=5
CODEXMANAGER_QUOTA_GUARD_WEEKLY_MIN_REMAINING_PERCENT=10
CODEXMANAGER_QUOTA_GUARD_ALLOW_ALL_LOW_FALLBACK=1

# Background refresh keeps usage/token state fresh enough for automatic failover.
CODEXMANAGER_USAGE_POLLING_ENABLED=1
CODEXMANAGER_USAGE_POLL_INTERVAL_SECS=300
CODEXMANAGER_TOKEN_REFRESH_POLLING_ENABLED=1
CODEXMANAGER_TOKEN_REFRESH_POLL_INTERVAL_SECS=300
CODEXMANAGER_GATEWAY_KEEPALIVE_ENABLED=1
CODEXMANAGER_GATEWAY_KEEPALIVE_INTERVAL_SECS=180

# Long-running Codex streams should not be cut too aggressively.
CODEXMANAGER_UPSTREAM_TOTAL_TIMEOUT_MS=0
CODEXMANAGER_UPSTREAM_STREAM_TIMEOUT_MS=600000
CODEXMANAGER_SSE_KEEPALIVE_INTERVAL_MS=15000

# Logs useful for remote gateway diagnosis.
CODEXMANAGER_GATEWAY_TRACE_STDOUT=1
CODEXMANAGER_GATEWAY_ERROR_STDOUT=1
CODEXMANAGER_GATEWAY_TRACE_STDOUT_SLOW_MS=5000

# Terminal login/key generation.
REMOTE_GATEWAY_LOGIN_TIMEOUT_SECS=900
REMOTE_GATEWAY_LOGIN_POLL_SECS=3
REMOTE_GATEWAY_API_KEY_NAME=remote-codex
REMOTE_CODEX_MODEL=gpt-5.4

# Codex App SSH integration.
# When enabled, background start writes ~/.codex/config.toml so app-server uses this gateway.
REMOTE_GATEWAY_CODEX_APP_CONFIGURE_ON_START=1
REMOTE_GATEWAY_CODEX_APP_CONFIG_PATH=~/.codex/config.toml
REMOTE_GATEWAY_CODEX_APP_KEY_PATH=~/.codex/remote-gateway-api-key
REMOTE_GATEWAY_CODEX_APP_PROVIDER_ID=remote_gateway
REMOTE_GATEWAY_CODEX_APP_PROVIDER_NAME="Remote Codex Gateway"
# Defaults to http://127.0.0.1:${REMOTE_GATEWAY_WEB_PORT}/v1 when empty.
# REMOTE_GATEWAY_CODEX_APP_BASE_URL=http://127.0.0.1:48761/v1
REMOTE_GATEWAY_CODEX_APP_WIRE_API=responses
# Warm model catalog and account route mappings so the first app-server request does not hit cold cache.
REMOTE_GATEWAY_CODEX_APP_WARM_MODELS=1
# Set to 1 only if you are okay with active Codex SSH sessions being dropped.
REMOTE_GATEWAY_CODEX_APP_RESTART_SERVER=0
